<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView configured for our multi-cell grid:
    surface_type=texture_view ensures the rendering surface is part of the
      regular View hierarchy and is clipped by parent bounds. With the
      default surface_view, RESIZE_MODE_ZOOM (and other modes that resize
      AspectRatioFrameLayout beyond the parent) can overdraw onto adjacent
      cells because SurfaceView's hardware-composed surface bypasses
      ViewGroup clipping in some cases.
    use_controller=false because we render our own controls overlay.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit" />
