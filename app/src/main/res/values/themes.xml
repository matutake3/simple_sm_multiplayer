<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      Compose で MaterialTheme を使うため、Activity 側のテーマは
      最低限のフルスクリーン挙動だけ用意する (NoActionBar / 黒背景 / ステータスバー透過なし)。
    -->
    <style name="Theme.SimpleSmMultiplayer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/player_bg</item>
        <item name="android:colorBackground">@color/player_bg</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

</resources>
